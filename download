import { Readable } from "node:stream";
import path from "node:path";
import { fileURLToPath } from "node:url";
import express from "express";
import {
  fetchRandomTrack,
  isAllowedAudioSource,
  sourceRequestHeaders,
  toClientTrack,
} from "./khinsider.js";

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const publicDirectory = path.resolve(__dirname, "../public");
const app = express();
const port = Number.parseInt(process.env.PORT ?? "3000", 10);
const randomBuffer = [];
let refillPromise = null;

app.disable("x-powered-by");
app.use((request, response, next) => {
  response.set({
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=()",
    "Content-Security-Policy": [
      "default-src 'self'",
      "img-src 'self' https: data:",
      "media-src 'self' blob:",
      "connect-src 'self'",
      "style-src 'self' 'unsafe-inline'",
      "script-src 'self'",
      "font-src 'self'",
      "object-src 'none'",
      "base-uri 'self'",
      "frame-ancestors 'none'",
    ].join("; "),
  });
  next();
});

app.use(
  express.static(publicDirectory, {
    etag: true,
    maxAge: process.env.NODE_ENV === "production" ? "1h" : 0,
  }),
);

async function refillBuffer(targetSize) {
  if (refillPromise) return refillPromise;

  refillPromise = (async () => {
    let failedAttempts = 0;

    while (randomBuffer.length < targetSize && failedAttempts < targetSize * 3) {
      try {
        const track = await fetchRandomTrack();
        if (!randomBuffer.some((candidate) => candidate.id === track.id)) {
          randomBuffer.push(track);
        }
      } catch {
        failedAttempts += 1;
      }
    }
  })().finally(() => {
    refillPromise = null;
  });

  return refillPromise;
}

app.get("/api/health", (_request, response) => {
  response.json({ ok: true, service: "laiue-radio" });
});

app.get("/api/tracks/random", async (request, response) => {
  const requestedCount = Number.parseInt(String(request.query.count ?? "1"), 10);
  const count = Number.isFinite(requestedCount)
    ? Math.min(Math.max(requestedCount, 1), 4)
    : 1;

  try {
    await refillBuffer(count);

    if (randomBuffer.length === 0) {
      throw new Error("The music source is temporarily unavailable.");
    }

    const tracks = randomBuffer.splice(0, count).map(toClientTrack);
    response.set("Cache-Control", "no-store");
    response.json({ tracks });

    void refillBuffer(4);
  } catch (error) {
    response.status(502).json({
      error: error instanceof Error ? error.message : "Could not load a random track.",
    });
  }
});

app.get("/api/stream", async (request, response) => {
  const source = String(request.query.src ?? "");
  const referer = String(request.query.ref ?? "");

  if (!isAllowedAudioSource(source)) {
    response.status(400).json({ error: "Unsupported audio source." });
    return;
  }

  const controller = new AbortController();
  response.on("close", () => {
    if (!response.writableEnded) controller.abort();
  });

  try {
    const headers = sourceRequestHeaders(referer);
    if (request.headers.range) headers.range = request.headers.range;

    const upstream = await fetch(source, {
      headers,
      redirect: "error",
      signal: controller.signal,
    });

    if (!upstream.ok || !upstream.body) {
      response.status(upstream.status || 502).end();
      return;
    }

    const forwardedHeaders = [
      "accept-ranges",
      "content-length",
      "content-range",
      "content-type",
      "etag",
      "last-modified",
    ];

    response.status(upstream.status);
    response.set("Cache-Control", "public, max-age=3600");
    for (const header of forwardedHeaders) {
      const value = upstream.headers.get(header);
      if (value) response.set(header, value);
    }

    Readable.fromWeb(upstream.body).pipe(response);
  } catch (error) {
    if (!controller.signal.aborted && !response.headersSent) {
      response.status(502).json({ error: "Could not stream this track." });
    }
  }
});

app.get("*path", (_request, response) => {
  response.sendFile(path.join(publicDirectory, "index.html"));
});

app.listen(port, () => {
  console.log(`laiue radio is listening on http://localhost:${port}`);
});
